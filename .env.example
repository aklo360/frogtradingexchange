# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. NEVER commit real credentials to git. Use .env.local for local dev.
# 2. For production: use Cloudflare Workers Secrets (`wrangler secret put`)
# 3. NEVER use NEXT_PUBLIC_* prefix for sensitive values - they get bundled
#    into client-side JavaScript and are visible to all users
# 4. Rotate credentials regularly and after any suspected exposure
# 5. Use environment-specific credentials for dev/staging/prod
# =============================================================================

# Titan API credentials (keep real values in `.env.local` or Wrangler secrets)
TITAN_BASE_URL=https://{region}.api.demo.titan.exchange/api/v1
TITAN_WS_URL=wss://{region}.api.demo.titan.exchange/api/v1/ws
TITAN_TOKEN=replace-with-your-token
TITAN_REGION_ORDER=us1,de1,jp1

# Quote freshness in seconds (default is 3)
QUOTE_FRESHNESS_SECONDS=10

# Worker-only Solana RPC endpoints (keep private - NEVER expose these)
# SECURITY: These are server-side only. Use /rpc proxy for frontend.
SOLANA_RPC_URL=https://your-private-solana-rpc.example.com
SOLANA_WS_URL=wss://your-private-solana-rpc.example.com

# Optional overrides for the Pages worker proxy
# API_ORIGIN=https://frogx-api.aklo.workers.dev

# Client-side overrides (CAUTION: NEXT_PUBLIC_* values are exposed to users!)
# SECURITY WARNING: Do NOT put API keys in NEXT_PUBLIC variables!
# Use the /rpc proxy endpoint instead of exposing RPC URLs directly.
# NEXT_PUBLIC_API_BASE_URL=https://frogx-api.aklo.workers.dev
# NEXT_PUBLIC_FROGX_VERSION=v1

# Platform fee configuration (1% default). Ensure fee collector ATAs exist for minted tokens.
PLATFORM_FEE_ENABLED=true
PLATFORM_FEE_BPS=100
PLATFORM_FEE_RECIPIENT=FRoGhxGx2kugimLMTiq3qra7yarFmnfpm6E3y38myzWh
# Optional explicit token accounts for fee collection when not using auto-derived ATAs.
PLATFORM_FEE_SOL_ACCOUNT=8ZS7hMekbggef1a2cbHj3U7UebLB4qWHH9PyGd6RMdye
PLATFORM_FEE_USDC_ACCOUNT=7NcR9WU2kzJV1RcN9NcGXakkbU9289rxZdAoyMxNuCsE
PLATFORM_FEE_USDT_ACCOUNT=7a2LNckdNtNFneyTiYiz5uZTYiL79vZvBUKPFCT2MXBa

# Buyback automation (Cloudflare Worker)
BUYBACK_ENABLED=true
BUYBACK_DRY_RUN=false
BUYBACK_BURN_ENABLED=true
# SECURITY: Store wallet secret using `wrangler secret put BUYBACK_WALLET_SECRET`
# NEVER store private keys in plaintext files that could be committed to git!
# BUYBACK_WALLET_SECRET=base58-or-json-array-secret-key
BUYBACK_WALLET_ADDRESS=FRoGhxGx2kugimLMTiq3qra7yarFmnfpm6E3y38myzWh
BUYBACK_SOL_RESERVE=0.05
BUYBACK_MIN_SWAP_USDC=1
BUYBACK_MIN_SWAP_USDT=1
BUYBACK_TOKEN_RESERVE_USDC=1
BUYBACK_TOKEN_RESERVE_USDT=1
BUYBACK_TOKEN_RESERVE_WSOL=1
BUYBACK_SWAP_SLIPPAGE_BPS=100
BUYBACK_PRIORITY_FEE=0
# SECURITY: Required for buyback endpoints. Generate with: openssl rand -hex 32
# BUYBACK_TRIGGER_TOKEN=replace-with-random-token

# Magic Eden buyback API
ME_API_BASE_URL=https://api-mainnet.magiceden.dev/v2
# ME_API_KEY=replace-with-magic-eden-api-key
# ME_API_KEY_HEADER=Authorization
# ME_API_KEY_PREFIX=Bearer
ME_COLLECTION_SYMBOL=solana_business_frogs
ME_STATS_PATH=/collections/{symbol}/stats
ME_LISTINGS_PATH=/collections/{symbol}/listings
ME_LISTINGS_QUERY=offset=0&limit=1&sort=price
ME_BUY_NOW_PATH=/instructions/buy_now
ME_BUY_NOW_METHOD=GET
ME_FLOOR_PRICE_UNIT=lamports

# Sol Incinerator API
# SOL_INCINERATOR_API_URL=https://v1.api.sol-incinerator.com
# SOL_INCINERATOR_API_KEY=replace-with-incinerator-key
# SOL_INCINERATOR_API_KEY_HEADER=x-api-key
# SOL_INCINERATOR_API_KEY_PREFIX=
# SOL_INCINERATOR_BURN_PATH=/burn
# SOL_INCINERATOR_BURN_METHOD=POST

# Tapestry social profiles (server-side only - NEVER expose to frontend)
# SECURITY: Store using `wrangler secret put TAPESTRY_API_KEY` for production
TAPESTRY_API_KEY=replace-with-tapestry-key
# TAPESTRY_NAMESPACE=frogx            # set to your Pages project namespace for profile filtering
